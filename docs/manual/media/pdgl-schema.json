{
    "$id": "https://pdgl.joe-starr.com/manual/media/pdgl-schema.json",
    "description": "Schema for a PDGL compatable grammar file.",

    "type": "object",
    "properties": {
        "production": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "$ref": "https://pdgl.joe-starr.com/manual/productions/pure/media/schema.json"
                    },
                    {
                        "$ref": "https://pdgl.joe-starr.com/manual/productions/weighted/media/schema.json"
                    },
                    {
                        "$ref": "https://pdgl.joe-starr.com/manual/productions/range/media/schema.json"
                    },
                    {
                        "$ref": "https://pdgl.joe-starr.com/manual/productions/janet/media/schema.json"
                    }
                ]
            },
            "contains": {
                "type": "object",
                "properties": {
                    "name": {
                        "const": "entry"
                    }
                }
            },
            "minLength": 1
        }
    },
    "additionalProperties": false,
    "minProperties": 1
}
