{
    "$id": "pure_production-schema",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
        },
        "type": {
            "type": "string",
            "const": "pure"
        },
        "replacements": {
            "type": "array",
            "items": { "type": "string", "minLength": 0, "maxLength": 3000 },
            "minLength": 1
        },
        "terminals": {
            "type": "array",
            "items": { "type": "string", "minLength": 0, "maxLength": 3000 },
            "minLength": 1
        }
    },
    "additionalProperties": false,
    "minProperties": 4
}
