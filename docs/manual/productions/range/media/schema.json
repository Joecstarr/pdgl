        "name": {
            "type": "string"
        },
        "type": {
            "const": "range"
        },
        "upper_bound": {
            "type": "integer"
        },
        "lower_bound": {
            "type": "integer"
        }
    },
    "additionalProperties": false,
    "minProperties": 4
}
